<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/headerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/test_pages"
        android:textSize="24sp"
        android:textStyle="bold"
        android:contentDescription="Test Pages Header"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/buttons_taps"
        android:contentDescription="Buttons &amp; Taps"
        app:icon="@android:drawable/ic_menu_edit"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/inputsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_inputs"
        android:contentDescription="Text Inputs"
        app:icon="@android:drawable/ic_menu_edit"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/listsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scrollable_lists"
        android:contentDescription="Scrollable Lists"
        app:icon="@android:drawable/ic_menu_agenda"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/formsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/form_controls"
        android:contentDescription="Form Controls"
        app:icon="@android:drawable/ic_menu_preferences" />

</LinearLayout>
